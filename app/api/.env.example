AZURE_SEARCH_SERVICE_ENDPOINT=https://<domain>.search.windows.net
AZURE_SEARCH_ADMIN_KEY=<key>
AZURE_OPENAI_ENDPOINT=https://<domain>.openai.azure.com

GEDS_API_TOKEN=secret
DATABASE_ENDPOINT=https://<something>.table.core.windows.net/
BLOB_ENDPOINT=https://<something>.blob.core.windows.net/

AZURE_AD_CLIENT_ID=api://<app-uuid>
AZURE_AD_TENANT_ID=d05bc194-94bf-4ad6-ae2e-1db0f2e38f5e

# OPTIONAL PARAMETERS
SKIP_USER_VALIDATION=False
ALLOWED_TOOLS=geds,corporate,archibus,pmcoe,telecom
AZURE_SEARCH_INDEX_NAME=current
ARCHIBUS_API_USERNAME=user
ARCHIBUS_API_PASSWORD=pass

BITS_DB_SERVER=domain:1234
BITS_DB_DATABASE=databaseName
BITS_DB_USERNAME=username
BITS_DB_PWD=password

SQL_CONNECTION_STRING=postgresql+psycopg://user:password@host:port/dbname

# Playground-only embedded LiteLLM gateway
# Runtime mode for gateway adapter. `embedded` uses in-process LiteLLM.
# `standalone_http` is a placeholder for future migration path and is not yet implemented.
LITELLM_GATEWAY_MODE=embedded
# If the incoming request does not provide `model`, this fallback model is used.
# Examples: azure/gpt-4o-mini, openai/gpt-4.1-mini
LITELLM_DEFAULT_MODEL=
# Optional model allow-list (comma-separated provider/model values).
# Example: azure/gpt-4o-mini,openai/gpt-4.1-mini
LITELLM_ALLOWED_MODELS=
# MCP transport fallback for tools without explicit `transport`.
# Use `http` for streamable MCP endpoints like http://127.0.0.1:8000/mcp.
LITELLM_DEFAULT_MCP_TRANSPORT=http
# Keep false for Azure Responses compatibility (tools[].transport is rejected).
LITELLM_INJECT_MCP_TRANSPORT=false
# Emit compact one-line JSON logs for the embedded LiteLLM gateway.
LITELLM_JSON_LOGS=true
# Forward incoming Authorization bearer token to LiteLLM as `azure_ad_token`.
# Keep disabled unless your incoming token audience is valid for Azure OpenAI.
LITELLM_FORWARD_CALLER_BEARER_TOKEN=false
# Optional policy toggles for embedded LiteLLM proxy behavior.
LITELLM_ENABLE_METRICS=false
LITELLM_ENABLE_GUARDRAILS=false
LITELLM_ENABLE_RETRY=false
LITELLM_RETRY_MAX_ATTEMPTS=1
LITELLM_RETRY_BACKOFF_MS=250
# Optional comma-separated fallback chain (provider/model values).
# Example: azure/gpt-4o-mini,openai/gpt-4.1-mini
LITELLM_FALLBACK_MODELS=
