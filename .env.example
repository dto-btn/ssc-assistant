# ssca-admin-dashboard environment variables
# Copy this file to .env.local and fill in real values.
# .env.local is gitignored.

# ─── Azure AD (MSAL) ─────────────────────────────────────────────────────────
# Client ID of the existing AAD app registration (same as ssc-assistant frontend)
VITE_AZURE_AD_CLIENT_ID=

# Tenant ID of your Azure AD tenant
VITE_AZURE_AD_TENANT_ID=

# API scope in the format api://<client-id>/<scope-name>
VITE_AZURE_AD_API_SCOPE=

# Optional: custom domain for the redirect URI (leave blank for localhost)
# When set, the redirect will go to <VITE_REDIRECT_URI_DOMAIN>/auth/callback
VITE_REDIRECT_URI_DOMAIN=

# ─── Analytics backend (litellm-proxy-standalone) ────────────────────────────
# Base URL of the analytics FastAPI service (must NOT end in /v1)
VITE_ANALYTICS_API_BASE_URL=http://localhost:4001

# ─── LiteLLM native admin endpoints ──────────────────────────────────────────
# Base URL including /v1 (used to derive the proxy root for /spend/logs etc.)
VITE_PLAYGROUND_LITELLM_BASE_URL=http://localhost:4000/v1

# Master key for LiteLLM native admin endpoints
VITE_PLAYGROUND_LITELLM_PROXY_KEY=

# ─── Feature flags ────────────────────────────────────────────────────────────
# Comma-separated list of features to disable.
# Example: VITE_DISABLED_FEATURES=AdminDashboard
VITE_DISABLED_FEATURES=
